# ─────────────────────────────────────────────────────────────
#  Krishna's Cafe — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to Git!
# ─────────────────────────────────────────────────────────────

# Supabase — get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# Your Vercel frontend URL (used for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Port (Render sets this automatically, leave as 3001 for local dev)
PORT=3001
